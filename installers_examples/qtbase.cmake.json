        "flags": [ "-DCMAKE_ASM_COMPILER=nasm", 
        "-DQT_FEATURE_wayland_server=ON", 
        "-DQT_FEATURE_wayland_client=ON"  ]
      },
      "macos": {
        "c_compiler": "clang",
        "cxx_compiler": "clang++",
        "flags": [ "-DCMAKE_ASM_COMPILER=nasm" ]
      },
      "freebsd": {
        "c_compiler": "clang",
        "cxx_compiler": "clang++",
        "flags": [ "-DCMAKE_ASM_COMPILER=nasm", 
        "-DQT_FEATURE_wayland_server=ON", 
        "-DQT_FEATURE_wayland_client=ON"  ]
      }
    }
  }
